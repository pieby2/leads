# Copy this to backend/.env and fill in your values

# Google Gemini — required for embeddings and chat
GEMINI_API_KEY=your-gemini-api-key-here

# Apify — required for Instagram scraping
APIFY_API_TOKEN=your-apify-api-token-here

# Postgres
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/vidcompare

# Qdrant
QDRANT_HOST=localhost
QDRANT_PORT=6333

# Model config (defaults are fine for most cases)
GEMINI_MODEL=gemini-2.5-flash
EMBEDDING_MODEL=gemini-embedding-2

# Chunking
CHUNK_SIZE=250
CHUNK_OVERLAP=30
