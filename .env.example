# Copy this to backend/.env and fill in your values

# OpenAI — required for embeddings and chat
OPENAI_API_KEY=sk-your-key-here

# Postgres
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/vidcompare

# Qdrant
QDRANT_HOST=localhost
QDRANT_PORT=6333

# Model config (defaults are fine for most cases)
GPT_MODEL=gpt-4o
GPT_MINI_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small

# Chunking
CHUNK_SIZE=250
CHUNK_OVERLAP=30
